[Unit]
Description=FilaBoss LCD UI
After=multi-user.target

[Service]
Type=simple
User=filaboss
Group=filaboss
WorkingDirectory=/home/filaboss/FilaBoss/python_lcd_ui
ExecStart=/home/filaboss/FilaBoss/python_lcd_ui/.venv/bin/python3 /home/filaboss/FilaBoss/python_lcd_ui/main.py --mode hw
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
